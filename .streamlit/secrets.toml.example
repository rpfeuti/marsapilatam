# Streamlit Cloud secrets — copy this file to .streamlit/secrets.toml
# and fill in your values, OR configure them in the Streamlit Cloud dashboard
# under App Settings → Secrets.
#
# Leave all Bloomberg fields empty / at defaults to run in demo mode.
# Demo mode uses pre-saved snapshots from demo_data/ and needs no credentials.
#
# To enable live Bloomberg MARS pricing, supply all three fields:
#   BBG_CLIENT_ID, BBG_CLIENT_SECRET, BBG_UUID
# and optionally override the API host with BBG_HOST.

# -----------------------------------------------------------------
# Bloomberg MARS API credentials (leave blank for demo mode)
# -----------------------------------------------------------------
BBG_CLIENT_ID     = ""
BBG_CLIENT_SECRET = ""
BBG_UUID          = 0

# Optional: override the default MARS API base URL
# BBG_HOST = "https://api.bloomberg.com"
